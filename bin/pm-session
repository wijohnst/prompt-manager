#!/bin/bash
set -euo pipefail

# pm-session: manage git worktree isolation for agent sessions
#
# Usage:
#   pm-session start <agent>
#   pm-session end <agent>

usage() {
  cat >&2 <<EOF
Usage: pm-session start|end <agent>

Commands:
  start <agent>   Create an isolated git worktree for the agent
  end <agent>     Push the branch, open a draft PR, and clean up the worktree

Environment:
  PM_ROOT         Repository root (default: current directory)
EOF
  exit 1
}

session_start() {
  local agent="$1"

  # Generate branch name: feat/<agent>-<timestamp>
  local timestamp=$(date +%Y%m%d%H%M%S)
  local branch_name="feat/${agent}-${timestamp}"

  # Worktree path: .pm/worktrees/<agent>-<timestamp>
  local worktree_path="${PM_ROOT}/.pm/worktrees/${agent}-${timestamp}"

  # Create .pm/worktrees directory
  mkdir -p "$(dirname "$worktree_path")"

  # Create worktree with new branch
  if ! git -C "$PM_ROOT" worktree add "$worktree_path" -b "$branch_name"; then
    echo "error: failed to create worktree at $worktree_path" >&2
    exit 1
  fi

  cat <<EOF
session started: $branch_name
worktree created at: $worktree_path
branch created: $branch_name

To work in this session, cd to: $worktree_path
To end this session, run: pm-session end $agent
EOF
}

session_end() {
  local agent="$1"

  # Find the most recent worktree for this agent
  local worktrees_dir="${PM_ROOT}/.pm/worktrees"
  local latest_worktree=""
  local latest_timestamp=""

  if [[ -d "$worktrees_dir" ]]; then
    while IFS= read -r -d '' entry; do
      local name=$(basename "$entry")
      if [[ "$name" == "${agent}-"* ]]; then
        local timestamp="${name#${agent}-}"
        if [[ "$timestamp" > "$latest_timestamp" ]]; then
          latest_timestamp="$timestamp"
          latest_worktree="$entry"
        fi
      fi
    done < <(find "$worktrees_dir" -mindepth 1 -maxdepth 1 -type d -print0)
  fi

  if [[ -z "$latest_worktree" ]]; then
    echo "error: no active session found for agent \"$agent\"" >&2
    echo "run: pm-session start $agent" >&2
    exit 1
  fi

  # Get the branch name from the worktree
  local branch_name
  if ! branch_name=$(git -C "$latest_worktree" rev-parse --abbrev-ref HEAD 2>/dev/null); then
    echo "error: failed to determine branch name from worktree" >&2
    exit 1
  fi

  cat <<EOF
ending session for agent "$agent"
branch: $branch_name
worktree: $latest_worktree

EOF

  # Check if there are any commits to push
  local ahead
  if ahead=$(git -C "$PM_ROOT" rev-list --count origin/main.."$branch_name" 2>/dev/null); then
    if [[ "$ahead" -eq 0 ]]; then
      echo "no changes detected on this branch"
      # Still tear down worktree even if no changes
      git -C "$PM_ROOT" worktree remove "$latest_worktree" || true
      echo "session ended"
      return 0
    fi
  fi

  # Push the branch
  echo "pushing branch \"$branch_name\" to origin..."
  if ! git -C "$PM_ROOT" push -u origin "$branch_name"; then
    echo "error: failed to push branch \"$branch_name\"" >&2
    exit 1
  fi

  # Open draft PR
  echo "opening draft PR for branch \"$branch_name\"..."
  if ! gh pr create --draft --base main --head "$branch_name" \
    --title "WIP: $branch_name" \
    --body "Session work in progress" 2>/dev/null; then
    # gh might fail if PR exists, which is okay — branch is still pushed
    echo "(PR creation skipped or already exists)"
  fi

  # Tear down worktree
  echo "removing worktree at $latest_worktree..."
  if ! git -C "$PM_ROOT" worktree remove "$latest_worktree"; then
    echo "error: failed to remove worktree at $latest_worktree" >&2
    echo "you may need to manually run: git worktree remove $latest_worktree" >&2
    exit 1
  fi

  echo "session ended"
}

# Main execution
if [[ $# -lt 2 ]]; then
  usage
fi

COMMAND="$1"
AGENT="$2"
PM_ROOT="${PM_ROOT:-.}"

# Validate git repo
if ! git -C "$PM_ROOT" rev-parse --git-dir > /dev/null 2>&1; then
  echo "error: not in a git repository" >&2
  exit 1
fi

case "$COMMAND" in
  start)
    session_start "$AGENT"
    ;;
  end)
    session_end "$AGENT"
    ;;
  *)
    usage
    ;;
esac
